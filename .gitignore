# ── dotfiles bare repo: protective ignores ──
# History / session files (can leak secrets, and are machine-local)
*.zsh_history
.zsh_history
.bash_history
*history*
.zsh_sessions/
.local/share/zsh/

# Generated zsh completion caches
*.zcompdump*
*.zwc

# Secrets / credentials (never track)
*.pem
*.key
id_rsa*
id_ed25519*
*.gpg
.netrc
.env
*secret*
*token*
*credential*

# Caches / build junk
__pycache__/
*.pyc
*.log
*.swp

# ── Heavy data dirs: track only specific config files, never the whole tree ──
.config/spicetify/*
!.config/spicetify/config-xpui.ini
.config/hyde/*
!.config/hyde/config.toml
!.config/hyde/themes
!.config/hyde/wallbash
# HyDE theme configs are tracked (~6MB text); wallpaper MEDIA is NOT
# (2GB of .mp4/.png — exceeds GitHub's 100MB/file limit; backed up separately)
.config/hyde/themes/**/wallpapers/
.config/hyde/themes/*.tar.gz
.config/hyde/themes/*.tar
.config/fastfetch/*
!.config/fastfetch/config.jsonc
!.config/fastfetch/config.conf
