#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage: $0 <directory>"
    exit 1
fi

DIR="$1"

if ! command -v fdupes &> /dev/null; then
    echo "fdupes not installed. Installing..."
    sudo pacman -S --noconfirm fdupes
fi

echo "Finding and deleting duplicates in $DIR ..."
fdupes -rdN "$DIR"
echo "Done!"
